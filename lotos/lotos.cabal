----------------------------------------------------------------------------------------------------
-- Demos: runnable examples that should not execute under `cabal test all`.
----------------------------------------------------------------------------------------------------

executable demo-conc-executor2
  import:      shared-properties, demo
  main-is:     ConcExecutor2.hs
  ghc-options: -threaded -rtsopts -with-rtsopts=-N
  build-depends:
    , directory

executable demo-event-trigger
  import:        shared-properties, demo
  main-is:       EventTrigger.hs
  build-depends: time

executable demo-logger
  import:        shared-properties, demo
  main-is:       Logger.hs
  build-depends:
    , mtl
    , vector

executable demo-simple-servant
  import:        shared-properties, demo
  main-is:       SimpleServant.hs
  build-depends:
    , aeson
    , servant
    , servant-server
    , text
